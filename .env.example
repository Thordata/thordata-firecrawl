# Thordata API Key (required)
# You can use either variable name. THORDATA_API_KEY is preferred in this repo.
THORDATA_API_KEY=your-thordata-api-key-here
# THORDATA_SCRAPER_TOKEN=your-thordata-api-key-here

# Optional: Thordata API Base URL
# THORDATA_BASE_URL=https://universalapi.thordata.com

# Crawl job controls (HTTP server)
MAX_CONCURRENT_CRAWLS=2
JOB_TTL_SECONDS=3600

# LLM Configuration (optional, required for agent functionality)
# OpenAI-compatible API (supports OpenAI, SiliconFlow, etc.)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=auto  # Auto-detect based on API_BASE, or specify: gpt-3.5-turbo, Qwen/Qwen2.5-7B-Instruct, etc.

# Examples for different providers:
# OpenAI: OPENAI_API_BASE=https://api.openai.com/v1, OPENAI_MODEL=gpt-3.5-turbo
# SiliconFlow: OPENAI_API_BASE=https://api.siliconflow.cn/v1, OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct
# DeepSeek: OPENAI_API_BASE=https://api.deepseek.com/v1, OPENAI_MODEL=deepseek-chat
